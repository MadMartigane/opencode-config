{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "brave-search": {
      "type": "local",
      "command": [
        "bun",
        "x",
        "@modelcontextprotocol/server-brave-search"
      ],
      "enabled": true,
      "environment": {
        "BRAVE_API_KEY": "{file:./keys/brave_api_key.txt}"
      }
    },
    "sequential-thinking": {
      "type": "local",
      "enabled": true,
      "command": [
        "bun",
        "x",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  },
  "provider": {
    "ovh-ai-internal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Internal OVH AI playwright_browser_handle_dialogpoint",
      "options": {
        "baseURL": "https://oai.endpoints.preprod.ai.cloud.ovh.net/v1/",
        "apiKey": "michael.baudchon@corp.ovh.com"
      },
      "models": {
        "Qwen/Qwen3-Coder-480B-A35B-Instruct-FP8": {
          "name": "Qwen3-Coder-480B-A35B-Instruct-FP8 (internal)",
          "limit": {
            "context": 256000,
            "output": 65536
          }
        },
        "gpt-oss-20b": {
          "name": "gpt-oss-20b (internal)",
          "limit": {
            "context": 131000,
            "output": 32768
          }
        }
      }
    }
  },
  "command": {
    "plan-validate": {
      "template": "Je valide le plan, passe à l'implémentation. Utilise au max les sous-agents pour économiser ton context et parallélise les tasks dès que possible.",
      "description": "Plan OK, go implementation !"
    },
    "plan-update": {
      "template": "$ARGUMENTS\n\nMets à jour le plan et soumets le moi à nouveau, pour validation.",
      "description": "Update the plan, wait validation."
    },
    "plan-build": {
      "template": "$ARGUMENTS\n\nÉlabore un plan, soumets le moi de façon résumée, élégente et facile à lire puis attends que je le valide.",
      "description": "Build the plan, wait validation."
    },
    "commit-push": {
      "template": "Ticket : $ARGUMENTS\n\nCommit et push les changements. Utilise **Git-Expert** pour générer un message conforme. Si un ticket est fourni (ou trouvé dans la branche), inclus-le en footer (ex: ref: TICKET-ID).\nIl est possible que des changements impactent plusieurs domaines distinct, si tel est le cas, split en plusieurs commits cohérents.",
      "description": "Commit and push changes with ticket reference."
    },
    "bug-find": {
      "template": "$ARGUMENTS\n\nUtilise le sous-agent **BugFinder** pour trouver l'origine du bug et élabrer un plan précis de correction. Je dois valider le plan avant toute implémentation.",
      "description": "Find bug, build plan, wait validation."
    },
    "challenge-advice": {
      "template": "Challenge, évalue la criticité et explique brièvement les remarques suivente qui portent sur des modifications récentes de code :\n$ARGUMENTS",
      "description": "Challenge review advices."
    },
    "resume" :{
      "template": "Résume ce qui vient d'être fait dans cette session dans `RESUME.md`. Si il existe écrase le sans confirmation, si il n'exsite pas crée le. Un agent de codage doit être capable de reprendre la session avec ce résumé.",
      "description": "Resume work un RESUME.md"
    }
  },
  "default_agent": "Rocket",
  "agent": {
  "plan": {
    "disable": true,
    "model": "{file:./models/plan_model.txt}",
    "temperature": 0.3,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "grep": true,
      "list": true,
      "edit": true,
      "write": true,
      "task": true,
      "skills*": false,
      "webfetch": true,
      "todowrite": true,
      "todoread": true,
      "brave-search_brave_web_search": false,
      "brave-search_brave_local_search": false,
      "sequential-thinking_sequentialthinking": true,
      "context7_*": false
    }
  },
  "build": {
    "disable": false,
    "model": "{file:./models/build_model.txt}",
    "temperature": 0.3,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "grep": true,
      "list": true,
      "edit": true,
      "write": true,
      "task": true,
      "skills*": false,
      "webfetch": true,
      "todowrite": true,
      "todoread": true,
      "brave-search_brave_web_search": false,
      "brave-search_brave_local_search": false,
      "sequential-thinking_sequentialthinking": true,
      "context7_*": false
    }
  },
  "Rocket": {
    "mode": "primary",
    "model": "{file:./models/rocket_model.txt}",
    "prompt": "{file:./prompts/rocket.md}",
    "temperature": 0.3,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "grep": true,
      "list": true,
      "edit": false,
      "write": false,
      "task": true,
      "skills*": false,
      "webfetch": true,
      "todowrite": true,
      "todoread": true,
      "brave-search_brave_web_search": false,
      "brave-search_brave_local_search": false,
      "sequential-thinking_sequentialthinking": true,
      "context7_*": false
    }
  },
  "Rocket-Review": {
    "mode": "primary",
    "model": "{file:./models/rocket_review_model.txt}",
    "prompt": "{file:./prompts/rocket-review.md}",
    "temperature": 0.1,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "grep": true,
      "list": true,
      "edit": false,
      "write": false,
      "task": true,
      "skills*": false,
      "webfetch": true,
      "todowrite": true,
      "todoread": true,
      "brave-search_brave_web_search": false,
      "brave-search_brave_local_search": false,
      "sequential-thinking_sequentialthinking": true,
      "context7_*": false
    }
  },
  "Chatbot": {
    "mode": "primary",
    "model": "{file:./models/chatbot_model.txt}",
    "prompt": "{file:./prompts/chatbot.md}",
    "temperature": 1,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "grep": true,
      "list": true,
      "edit": true,
      "write": true,
      "task": true,
      "skills*": false,
      "webfetch": true,
      "todowrite": true,
      "todoread": true,
      "brave-search_brave_web_search": true,
      "brave-search_brave_local_search": false,
      "sequential-thinking_sequentialthinking": true,
      "context7_*": true
    }
  },
  "Code-Audit": {
    "mode": "subagent",
    "model": "{file:./models/code_audit_model.txt}",
    "prompt": "{file:./prompts/code-audit.md}",
    "temperature": 0.1,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "list": true,
      "edit": true,
      "write": false,
      "task": false,
      "skills*": false,
      "webfetch": true,
      "todowrite": false,
      "todoread": false,
      "brave-search_brave_web_search": true,
      "brave-search_brave_local_search": false,
      "sequential-thinking_sequentialthinking": true,
      "context7_*": true
    }
  },
  "Code-Only": {
    "mode": "subagent",
    "description": "Primary subagent for code implementation. Specialized in precise file modifications and creation based on technical specs. Use this agent for all physical coding tasks to maintain context efficiency.",
    "prompt": "{file:./prompts/code-only.md}",
    "model": "{file:./models/code_only_model.txt}",
    "temperature": 0.1,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "grep": true,
      "list": true,
      "edit": true,
      "write": true,
      "task": true,
      "skills*": false,
      "skills_clean-code": true,
      "webfetch": false,
      "todowrite": false,
      "todoread": false,
      "brave-search_brave_web_search": false,
      "brave-search_brave_local_search": false,
      "sequential-thinking_sequentialthinking": true,
      "context7_*": false
    }
  },
  "Code-Smoke": {
    "mode": "subagent",
    "description": "Lightweight per-task smoke check agent. Runs fast scoped validation (lint, tsc, unit tests on changed files) after each Code-Only task. No refinement, no skill loading, no full test suites. Use this agent for rapid blocking-error detection in the Rocket per-task loop.",
    "prompt": "{file:./prompts/code-smoke.md}",
    "model": "{file:./models/code_smoke_model.txt}",
    "temperature": 0.1,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "grep": true,
      "list": true,
      "edit": false,
      "write": false,
      "task": false,
      "skills*": false,
      "todowrite": false,
      "todoread": false,
      "brave-search_brave_web_search": false,
      "brave-search_brave_local_search": false,
      "sequential-thinking_sequentialthinking": false,
      "context7_*": false
    }
  },
  "Code-Cleaner": {
    "mode": "subagent",
    "description": "Full QA and Code Refinement specialist. Called once after all tasks are completed in the Rocket workflow. Runs complete test suites via Test-Expert, applies clean-code refinements, and ensures global consistency across all changes.",
    "prompt": "{file:./prompts/code-cleaner.md}",
    "model": "{file:./models/code_cleaner_model.txt}",
    "temperature": 0.1,
    "tools": {
      "bash": true,
      "read": true,
      "edit": true,
      "glob": true,
      "grep": true,
      "write": true,
      "task": true,
      "todowrite": false,
      "todoread": false,
      "brave-search_brave_web_search": false,
      "brave-search_brave_local_search": false,
      "sequential-thinking_sequentialthinking": true,
      "context7_*": false
    }
  },
  "Test-Expert": {
    "mode": "subagent",
    "description": "Specialized in running tests and providing concise summaries. Use this agent to avoid context pollution from verbose test logs.",
    "prompt": "{file:./prompts/test-expert.md}",
    "model": "{file:./models/test_expert_model.txt}",
    "temperature": 0.1,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "grep": true,
      "list": true,
      "task": false,
      "skills*": false,
      "write": false,
      "todowrite": false,
      "todoread": false,
      "sequential-thinking_sequentialthinking": true,
      "context7_*": false
    }
  },
  "Git-Expert": {
    "mode": "subagent",
    "description": "Specialized Git manager. Use this agent for all repository operations: generating conventional commits, rebasing, and cleaning history. This is the only authorized agent for Git-related tasks.",
    "model": "{file:./models/git_expert_model.txt}",
    "prompt": "{file:./prompts/git-expert.md}",
    "temperature": 0.1,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "grep": true,
      "list": true,
      "skill": true,
      "task": false,
      "skills*": false,
      "skills_git-branch-cleaner": true,
      "skills_git-commit-messages": true,
      "write": false,
      "todowrite": false,
      "todoread": false,
      "playwright_browser_*": false,
      "brave-search_brave_web_search": false,
      "brave-search_brave_local_search": false,
      "sequential-thinking_sequentialthinking": false,
      "context7_*": false
    }
  },
  "Router-review": {
    "mode": "subagent",
    "description": "Lightweight triage agent for the Rocket-Review workflow. Analyzes Git diffs and selects relevant audit focuses.",
    "model": "{file:./models/router_review_model.txt}",
    "prompt": "{file:./prompts/router-review.md}",
    "temperature": 0.1,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "list": true,
      "task": false,
      "sequential-thinking_sequentialthinking": true,
      "context7_*": false
    }
  },
  "Critic-review": {
    "mode": "subagent",
    "description": "Senior auditor and technical critic for the Rocket-Review workflow. Consolidates and challenges multiple audit reports.",
    "model": "{file:./models/critic_review_model.txt}",
    "prompt": "{file:./prompts/critic-review.md}",
    "temperature": 0.1,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "list": true,
      "task": false,
      "sequential-thinking_sequentialthinking": true,
      "context7_*": false
    }
  },
  "Architect": {
    "mode": "subagent",
    "description": "Senior software architect for technical solution design and architecture decisions. Use this agent to design features, plan refactoring, or make technology choices. Read-only: produces structured architecture reports.",
    "model": "{file:./models/architect_model.txt}",
    "prompt": "{file:./prompts/architect.md}",
    "temperature": 0.1,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "grep": true,
      "list": true,
      "edit": false,
      "write": false,
      "task": false,
      "skills*": false,
      "webfetch": true,
      "todowrite": false,
      "todoread": false,
      "brave-search_brave_web_search": true,
      "brave-search_brave_local_search": false,
      "sequential-thinking_sequentialthinking": true,
      "context7_*": true
    }
  },
  "BugFinder": {
    "mode": "subagent",
    "description": "Senior software investigator for root cause analysis and systematic debugging. Use this agent to find the origin of bugs through deep codebase investigation. Read-only: produces structured bug analysis reports.",
    "model": "{file:./models/bugfinder_model.txt}",
    "prompt": "{file:./prompts/bugfinder.md}",
    "temperature": 0.1,
    "tools": {
      "bash": true,
      "read": true,
      "glob": true,
      "grep": true,
      "list": true,
      "edit": false,
      "write": false,
      "task": false,
      "skills*": false,
      "webfetch": true,
      "todowrite": false,
      "todoread": false,
      "brave-search_brave_web_search": true,
      "brave-search_brave_local_search": false,
      "sequential-thinking_sequentialthinking": true,
      "context7_*": true
    }
  }
}
}
