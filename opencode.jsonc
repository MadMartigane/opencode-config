{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "brave-search": {
      "type": "local",
      "command": [
        "bun",
        "x",
        "@modelcontextprotocol/server-brave-search"
      ],
      "enabled": true,
      "environment": {
        "BRAVE_API_KEY": "{file:./keys/brave_api_key.txt}"
      }
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "bun",
        "x",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  },
  "provider": {
    "ovh-ai-internal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Internal OVH AI",
      "options": {
        "baseURL": "https://oai.endpoints.preprod.ai.cloud.ovh.net/v1/",
        "apiKey": "michael.baudchon@corp.ovh.com"
      },
      "models": {
        "Qwen/Qwen3.5-397B-A17B": {
          "name": "Qwen3.5-397B-A17B (internal)",
          "limit": {
            "context": 256000,
            "output": 65536
          }
        },
        "gpt-oss-20b": {
          "name": "gpt-oss-20b (internal)",
          "limit": {
            "context": 131000,
            "output": 32768
          }
        },
        "gpt-oss-120b": {
          "name": "gpt-oss-120b (internal)",
          "limit": {
            "context": 131000,
            "output": 32768
          }
        }
      }
    }
  },
  "default_agent": "rocket",
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "explore": {
      "disable": false,
      "model": "{file:./models/coder.txt}",
      "prompt": "{file:./prompts/explore.md}",
      "temperature": 0.1
    },
    "rocket": {
      "mode": "primary",
      "model": "{file:./models/agentic.txt}",
      "prompt": "{file:./prompts/rocket.md}",
      "temperature": 0.3,
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "edit": false,
        "write": false,
        "task": true,
        "todowrite": true,
        "todoread": true,
        "sequential-thinking_sequentialthinking": true
      }
    },
    "rocket-review": {
      "mode": "primary",
      "model": "{file:./models/agentic.txt}",
      "prompt": "{file:./prompts/rocket-review.md}",
      "temperature": 0.1,
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "edit": false,
        "write": false,
        "task": true,
        "webfetch": true,
        "todowrite": true,
        "todoread": true,
        "sequential-thinking_sequentialthinking": true
      }
    },
    "chatbot": {
      "mode": "primary",
      "model": "{file:./models/agentic.txt}",
      "prompt": "{file:./prompts/chatbot.md}",
      "temperature": 1,
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "edit": true,
        "write": true,
        "task": true,
        "webfetch": true,
        "todowrite": true,
        "todoread": true,
        "brave-search_brave_web_search": true,
        "sequential-thinking_sequentialthinking": true,
        "context7_*": true
      }
    },
    "code-audit": {
      "mode": "subagent",
      "model": "{file:./models/thinker.txt}",
      "prompt": "{file:./prompts/code-audit.md}",
      "temperature": 0.1,
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "list": true,
        "edit": true,
        "write": false,
        "webfetch": true,
        "brave-search_brave_web_search": true,
        "sequential-thinking_sequentialthinking": true,
        "context7_*": true
      }
    },
    "code-only": {
      "mode": "subagent",
      "description": "Primary subagent for code implementation. Specialized in precise file modifications and creation based on technical specs. Use this agent for all physical coding tasks to maintain context efficiency.",
      "model": "{file:./models/coder.txt}",
      "prompt": "{file:./prompts/code-only.md}",
      "temperature": 0.1,
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "edit": true,
        "write": true,
        "task": true,
        "skills_clean-code": true,
        "sequential-thinking_sequentialthinking": true
      }
    },
    "code-smoke": {
      "mode": "subagent",
      "description": "Reporting-only validation agent. Per-task mode: syntax + lint for rapid blocking-error detection. Final mode: syntax + lint + tests + build for complete validation. Provides succinct PASS output or detailed diagnostic reports on failure. Use for all validation in the rocket workflow.",
      "model": "{file:./models/simple-fast.txt}",
      "prompt": "{file:./prompts/code-smoke.md}",
      "temperature": 0.1,
      "reminder": "You are a reporting-only validation agent. NEVER modify code. Two output modes: PASS = '✅ SMOKE PASSED' (single line); FAIL = detailed diagnostic report with What/Where/Why/Action Required sections. NO skill loading, NO delegation.",
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "edit": false,
        "write": false
      }
    },
    "git-expert": {
      "mode": "subagent",
      "description": "Specialized Git manager. Use this agent for all repository operations: generating conventional commits, rebasing, and cleaning history. This is the only authorized agent for Git-related tasks.",
      "model": "{file:./models/simple-fast.txt}",
      "prompt": "{file:./prompts/git-expert.md}",
      "temperature": 0.1,
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "skill": true,
        "skills_git-branch-cleaner": true,
        "skills_git-commit-messages": true,
        "edit": false,
        "write": false
      }
    },
    "router-review": {
      "mode": "subagent",
      "description": "Lightweight triage agent for the rocket-review workflow. Analyzes Git diffs and selects relevant audit focuses.",
      "model": "{file:./models/coder.txt}",
      "prompt": "{file:./prompts/router-review.md}",
      "temperature": 0.1,
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "list": true,
        "edit": false,
        "write": false,
        "sequential-thinking_sequentialthinking": true
      }
    },
    "critic-review": {
      "mode": "subagent",
      "description": "Senior auditor and technical critic for the rocket-review workflow. Consolidates and challenges multiple audit reports.",
      "model": "{file:./models/thinker.txt}",
      "prompt": "{file:./prompts/critic-review.md}",
      "temperature": 0.1,
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "list": true,
        "edit": false,
        "write": false,
        "sequential-thinking_sequentialthinking": true
      }
    },
    "architect": {
      "mode": "subagent",
      "description": "Senior software architect for technical solution design and architecture decisions. Use this agent to design features, plan refactoring, or make technology choices. Read-only: produces structured architecture reports.",
      "model": "{file:./models/thinker.txt}",
      "prompt": "{file:./prompts/architect.md}",
      "temperature": 0.1,
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "edit": false,
        "write": false,
        "task": true,
        "webfetch": true,
        "brave-search_brave_web_search": true,
        "sequential-thinking_sequentialthinking": true,
        "context7_*": true
      }
    },
    "architect-thinker": {
      "mode": "subagent",
      "description": "Diverse architectural reasoning worker for Self-Consistency",
      "model": "{file:./models/thinker.txt}",
      "prompt": "{file:./prompts/architect.md}",
      "temperature": 0.7,
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "edit": false,
        "write": false,
        "webfetch": true,
        "brave-search_brave_web_search": true,
        "sequential-thinking_sequentialthinking": true,
        "context7_*": true
      }
    },
    "bugfinder": {
      "mode": "subagent",
      "description": "Senior software investigator for root cause analysis and systematic debugging. Use this agent to find the origin of bugs through deep codebase investigation. Read-only: produces structured bug analysis reports.",
      "model": "{file:./models/thinker.txt}",
      "prompt": "{file:./prompts/bugfinder.md}",
      "temperature": 0.1,
      "tools": {
        "bash": true,
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "edit": false,
        "write": false,
        "webfetch": true,
        "brave-search_brave_web_search": true,
        "sequential-thinking_sequentialthinking": true,
        "context7_*": true
      }
    }
  }
}
